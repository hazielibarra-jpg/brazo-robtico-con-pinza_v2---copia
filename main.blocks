<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="(uxa?`qm/W+V,nE@xc^4" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="(;9wS%SVx7:=[(_n1$Fo"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace brazoRobotico {" line1="    let velocidad = 10" line2="" line3="    let pinBase = AnalogPin.P0" line4="    let pinBrazo1 = AnalogPin.P1" line5="    let pinBrazo2 = AnalogPin.P2" line6="    let pinPinza = AnalogPin.P15" line7="" line8="    let base_inicio = 70" line9="    let base_fin = 120" line10="" line11="    let brazo1_inicio = 80" line12="    let brazo1_fin = 120" line13="" line14="    let brazo2_inicio = 135" line15="    let brazo2_fin = 90" line16="" line17="    let pinza_abierta = 90" line18="    let pinza_cerrada = 50" line19="" line20="    function moverServo(pin: AnalogPin, inicio: number, fin: number): void {" line21="        if (inicio &lt; fin) {" line22="            for (let pos = inicio; pos &lt;= fin; pos++) {" line23="                pins.servoWritePin(pin, pos)" line24="                basic.pause(velocidad)" line25="            }" line26="        } else {" line27="            for (let pos2 = inicio; pos2 &gt;= fin; pos2--) {" line28="                pins.servoWritePin(pin, pos2)" line29="                basic.pause(velocidad)" line30="            }" line31="        }" line32="    }" line33="" line34="    /**" line35="     * Configura los pines donde están conectados los servomotores." line36="     * @param base pin del servo de la base" line37="     * @param brazo1 pin del servo del brazo 1" line38="     * @param brazo2 pin del servo del brazo 2" line39="     * @param pinza pin del servo de la pinza" line40="     */" line41="    //% block=&quot;configurar pines base %base brazo1 %brazo1 brazo2 %brazo2 pinza %pinza&quot;" line42="    //% base.defl=AnalogPin.P0" line43="    //% brazo1.defl=AnalogPin.P1" line44="    //% brazo2.defl=AnalogPin.P2" line45="    //% pinza.defl=AnalogPin.P15" line46="    export function configurarPines(base: AnalogPin, brazo1: AnalogPin, brazo2: AnalogPin, pinza: AnalogPin): void {" line47="        pinBase = base" line48="        pinBrazo1 = brazo1" line49="        pinBrazo2 = brazo2" line50="        pinPinza = pinza" line51="    }" line52="" line53="    /**" line54="     * Configura la velocidad de movimiento." line55="     * Entre más grande el número, más lento se mueve." line56="     * @param nuevaVelocidad pausa entre grados en milisegundos" line57="     */" line58="    //% block=&quot;configurar velocidad %nuevaVelocidad ms&quot;" line59="    //% nuevaVelocidad.defl=10" line60="    export function configurarVelocidad(nuevaVelocidad: number): void {" line61="        velocidad = nuevaVelocidad" line62="    }" line63="" line64="    /**" line65="     * Configura los grados de inicio y fin de la base." line66="     */" line67="    //% block=&quot;configurar base inicio %inicio fin %fin&quot;" line68="    //% inicio.defl=70" line69="    //% fin.defl=120" line70="    export function configurarBase(inicio: number, fin: number): void {" line71="        base_inicio = inicio" line72="        base_fin = fin" line73="    }" line74="" line75="    /**" line76="     * Configura los grados de inicio y fin del brazo 1." line77="     */" line78="    //% block=&quot;configurar brazo 1 inicio %inicio fin %fin&quot;" line79="    //% inicio.defl=80" line80="    //% fin.defl=120" line81="    export function configurarBrazo1(inicio: number, fin: number): void {" line82="        brazo1_inicio = inicio" line83="        brazo1_fin = fin" line84="    }" line85="" line86="    /**" line87="     * Configura los grados de inicio y fin del brazo 2." line88="     */" line89="    //% block=&quot;configurar brazo 2 inicio %inicio fin %fin&quot;" line90="    //% inicio.defl=135" line91="    //% fin.defl=90" line92="    export function configurarBrazo2(inicio: number, fin: number): void {" line93="        brazo2_inicio = inicio" line94="        brazo2_fin = fin" line95="    }" line96="" line97="    /**" line98="     * Configura los grados de la pinza abierta y cerrada." line99="     */" line100="    //% block=&quot;configurar pinza abierta %abierta cerrada %cerrada&quot;" line101="    //% abierta.defl=90" line102="    //% cerrada.defl=50" line103="    export function configurarPinza(abierta: number, cerrada: number): void {" line104="        pinza_abierta = abierta" line105="        pinza_cerrada = cerrada" line106="    }" line107="" line108="    /**" line109="     * Mueve todos los servos a la posición inicial." line110="     */" line111="    //% block=&quot;ir a posición inicial&quot;" line112="    export function posicionInicial(): void {" line113="        pins.servoWritePin(pinBase, base_inicio)" line114="        pins.servoWritePin(pinBrazo1, brazo1_inicio)" line115="        pins.servoWritePin(pinBrazo2, brazo2_inicio)" line116="        pins.servoWritePin(pinPinza, pinza_abierta)" line117="    }" line118="" line119="    /**" line120="     * Mueve la base desde inicio hasta fin." line121="     */" line122="    //% block=&quot;base ida&quot;" line123="    export function baseIda(): void {" line124="        moverServo(pinBase, base_inicio, base_fin)" line125="    }" line126="" line127="    /**" line128="     * Mueve la base desde fin hasta inicio." line129="     */" line130="    //% block=&quot;base regreso&quot;" line131="    export function baseRegreso(): void {" line132="        moverServo(pinBase, base_fin, base_inicio)" line133="    }" line134="" line135="    /**" line136="     * Mueve el brazo 1 desde inicio hasta fin." line137="     */" line138="    //% block=&quot;brazo 1 ida&quot;" line139="    export function brazo1Ida(): void {" line140="        moverServo(pinBrazo1, brazo1_inicio, brazo1_fin)" line141="    }" line142="" line143="    /**" line144="     * Mueve el brazo 1 desde fin hasta inicio." line145="     */" line146="    //% block=&quot;brazo 1 regreso&quot;" line147="    export function brazo1Regreso(): void {" line148="        moverServo(pinBrazo1, brazo1_fin, brazo1_inicio)" line149="    }" line150="" line151="    /**" line152="     * Mueve el brazo 2 desde inicio hasta fin." line153="     */" line154="    //% block=&quot;brazo 2 ida&quot;" line155="    export function brazo2Ida(): void {" line156="        moverServo(pinBrazo2, brazo2_inicio, brazo2_fin)" line157="    }" line158="" line159="    /**" line160="     * Mueve el brazo 2 desde fin hasta inicio." line161="     */" line162="    //% block=&quot;brazo 2 regreso&quot;" line163="    export function brazo2Regreso(): void {" line164="        moverServo(pinBrazo2, brazo2_fin, brazo2_inicio)" line165="    }" line166="" line167="    /**" line168="     * Abre la pinza." line169="     */" line170="    //% block=&quot;abrir pinza&quot;" line171="    export function abrirPinza(): void {" line172="        moverServo(pinPinza, pinza_cerrada, pinza_abierta)" line173="    }" line174="" line175="    /**" line176="     * Cierra la pinza." line177="     */" line178="    //% block=&quot;cerrar pinza&quot;" line179="    export function cerrarPinza(): void {" line180="        moverServo(pinPinza, pinza_abierta, pinza_cerrada)" line181="    }" line182="" line183="    /**" line184="     * Mueve un servo manualmente a cierto ángulo." line185="     * @param pin pin del servo" line186="     * @param grados ángulo del servo" line187="     */" line188="    //% block=&quot;mover servo en pin %pin a %grados grados&quot;" line189="    //% grados.defl=90" line190="    export function moverServoManual(pin: AnalogPin, grados: number): void {" line191="        pins.servoWritePin(pin, grados)" line192="    }" line193="}" numlines="194"></mutation></block></statement></block></xml>